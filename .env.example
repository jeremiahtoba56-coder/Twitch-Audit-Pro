# Copy this to a file named exactly ".env" (same folder as app.js)
# Fill in your values — you need Client ID + either Access Token OR Client Secret

# From https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=

# OPTION A — Pre-generated access token (simpler, expires after ~60 days)
# Generate one at https://twitchtokengenerator.com → App Access Token
TWITCH_ACCESS_TOKEN=

# OPTION B — Client Secret (auto-refreshes tokens, better for production)
# Click "New Secret" in your Twitch dev console app settings
TWITCH_CLIENT_SECRET=

# Optional — change the local port (default: 8787)
# PORT=8787
