# ------------------------------------------------------------------
# Twitch Audit Pro — local server environment
#
# 1. Copy this file to ".env" (same folder)
# 2. Fill in your real values below
# 3. Never commit ".env" to git, never paste it into a chat,
#    never upload it anywhere. Only ".env.example" (this file,
#    with blank values) is safe to share.
# ------------------------------------------------------------------

# From https://dev.twitch.tv/console/apps -> your app -> Client ID
TWITCH_CLIENT_ID=

# Your app's Client Secret (same console page -> "New Secret")
# The server uses this to automatically generate and refresh its
# own access tokens via the OAuth Client Credentials flow, so you
# never need to paste a raw access token anywhere.
TWITCH_CLIENT_SECRET=

# Port the local API server runs on
PORT=8787
